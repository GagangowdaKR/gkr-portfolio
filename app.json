{
  "expo": {
    "name": "GKR Portfolio",
    "slug": "gkr-portfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.gagank22.gkrportfolio",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "metaData": {
        "com.google.ar.core": "optional"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.portfolio.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "scheme": "portfolio",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a360064f-3add-471b-bb3a-71e624e49efe"
      }
    },
    "owner": "gagank22"
  }
}